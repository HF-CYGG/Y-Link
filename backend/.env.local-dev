# 本地专属调试 profile：
# - 独立 SQLite 文件写入 backend/data/local-dev/；
# - 开启 DB_SYNC 方便本地联调时自动同步实体结构；
# - 不影响默认 .env、Docker 或生产部署配置。
APP_PROFILE=local-dev
NODE_ENV=development
PORT=3001
DB_TYPE=sqlite
SQLITE_DB_PATH=./data/local-dev/y-link.local-dev.sqlite
DB_SYNC=true
INIT_ADMIN_PASSWORD=LocalDev@2026
VERIFICATION_CODE_REQUEST_TIMEOUT_MS=8000
