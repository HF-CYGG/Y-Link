# 模块说明：后端环境变量模板（通用）
# 文件职责：提供后端服务在本地/服务器运行时的环境变量默认示例
# 维护说明：新增后端必需环境变量时，需同步更新此模板并保持注释说明一致

NODE_ENV=development
PORT=3001
APP_PROFILE=default

# 可选：显式指定额外 env 文件。
# - 留空：仅按 `.env` / `.env.<APP_PROFILE>` 规则加载
# - 填写：最终再加载该文件，可覆盖前面的配置
ENV_FILE=

# 数据库模式：
# - sqlite：默认一体化部署，自动创建本地 SQLite 文件
# - mysql：连接外置 MySQL 服务
DB_TYPE=sqlite

# SQLite 一体化模式配置
# - default profile 默认写入 ./data/y-link.sqlite
# - 非 default profile 且未显式设置时，默认写入 ./data/local-dev/y-link.<profile>.sqlite
SQLITE_DB_PATH=./data/y-link.sqlite

# MySQL 分体化模式配置（当 DB_TYPE=mysql 时生效）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=y_link

# 是否启用 TypeORM synchronize：
# - 留空时：SQLite 首次启动自动建表，MySQL 默认关闭
# - true：每次启动同步实体结构（仅建议本地开发使用）
# - false：完全关闭自动同步
DB_SYNC=

# 登录态有效时长（小时）
AUTH_TOKEN_TTL_HOURS=168

# 首次启动默认管理员初始化账号
INIT_ADMIN_USERNAME=admin
# 安全要求：必须显式填写私有强密码，禁止继续使用历史默认口令
INIT_ADMIN_PASSWORD=请替换为你自己的私有强密码
INIT_ADMIN_DISPLAY_NAME=系统管理员

# 验证码平台外部请求超时（毫秒）
VERIFICATION_CODE_REQUEST_TIMEOUT_MS=8000
