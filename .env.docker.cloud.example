#
# 文件说明：云端镜像部署的环境变量模板。
# 实现逻辑：
# 1. 同时支持前后端镜像地址、端口、日志颜色和数据库连接配置；
# 2. 默认以 SQLite 一体化模式启动，也可切换到外置 MySQL；
# 3. 启动时可顺带初始化默认管理员账号，便于首次部署快速登录。
#
FRONTEND_IMAGE=docker.io/yemiao351/y-link-frontend:latest
BACKEND_IMAGE=docker.io/yemiao351/y-link-backend:latest
FRONTEND_PORT=8080
BACKEND_PORT=3001
LOG_COLOR=true
FORCE_COLOR=1
DB_TYPE=sqlite
SQLITE_DB_PATH=/app/data/y-link.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=y_link
DB_SYNC=false
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_DISPLAY_NAME=系统管理员
INIT_ADMIN_PASSWORD=Admin@123456
