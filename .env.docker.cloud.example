# 模块说明：Docker 部署环境变量配置
# 文件职责：提供云端 Docker 部署的环境变量参考模板
# 维护说明：当系统新增必须的部署环境变量时，需同步更新此模板文件

#
# 文件说明：云端镜像部署的环境变量模板。
# 实现逻辑：
# 1. 同时支持前后端镜像地址、端口、日志颜色和数据库连接配置；
# 2. 默认以 SQLite 一体化模式启动，也可切换到外置 MySQL；
# 3. 首次启动必须在容器面板环境变量中手动配置管理员初始化私有密码。
#
FRONTEND_IMAGE=docker.io/yemiao351/y-link-frontend:latest
BACKEND_IMAGE=docker.io/yemiao351/y-link-backend:latest
FRONTEND_PORT=8080
BACKEND_PORT=3001
TZ=Asia/Shanghai
LOG_COLOR=true
FORCE_COLOR=1
DB_TYPE=sqlite
SQLITE_DB_PATH=/app/data/y-link.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=y_link
DB_SYNC=false
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_DISPLAY_NAME=系统管理员
# 必填：请在 1Panel / Docker 面板环境变量中手动填写私有强密码，不要提交真实密码。
INIT_ADMIN_PASSWORD=
# 可选但建议：永久删除订单/送货单时使用的二次门禁密码；不配置时永久删除接口会被拒绝。
PERMANENT_DELETE_PASSWORD=
# 教师邀请码 HMAC 密钥：至少 32 个随机字节；不配置时教师邀请码接口不可用。
INVITE_CODE_PEPPER=
