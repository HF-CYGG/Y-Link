# 模块说明：Docker 外置 MySQL 部署环境变量配置
# 文件职责：提供云端 Docker 结合外置 MySQL 的部署环境变量参考模板
# 维护说明：当系统新增必须的部署环境变量时，需同步更新此模板文件

#
# 文件说明：Docker + 外置 MySQL 部署的环境变量模板。
# 实现逻辑：
# 1. 复制为 `.env.docker.mysql` 后填写真实的 MySQL 连接参数；
# 2. 先执行 `backend/sql/001_init_schema.sql` 完成建库建表；
# 3. 再配合 `compose.mysql.yml` 启动前后端应用容器。
#

# 宿主机端口映射
FRONTEND_PORT=8080
BACKEND_PORT=3001
TZ=Asia/Shanghai

# 外置 MySQL 连接信息
# - 如果 MySQL 部署在宿主机本机，可优先尝试 host.docker.internal
# - 如果是局域网或云数据库，请替换为真实可达地址
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=y_link

# 是否允许 TypeORM 自动同步：
# - false：推荐，先执行 SQL 脚本后再启动
# - true：仅建议开发环境临时调试使用
DB_SYNC=false

# 首次管理员初始化：
# - 必填：请在 1Panel / Docker 面板环境变量中手动填写私有强密码，不要提交真实密码。
# - 系统会拒绝历史弱口令 Admin@123456。
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_DISPLAY_NAME=系统管理员
INIT_ADMIN_PASSWORD=
# 可选但建议：永久删除订单/送货单时使用的二次门禁密码；不配置时永久删除接口会被拒绝。
PERMANENT_DELETE_PASSWORD=
# 教师邀请码 HMAC 密钥：至少 32 个随机字节；不配置时教师邀请码接口不可用。
INVITE_CODE_PEPPER=
