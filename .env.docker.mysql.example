# Docker + 外置 MySQL 模式环境模板
# 使用方式：
# 1) 复制为 .env.docker.mysql
# 2) 按实际 MySQL 地址、账号、库名修改
# 3) 先执行 backend/sql/001_init_schema.sql 完成建库建表
# 4) 再运行：docker compose --env-file .env.docker.mysql -f compose.mysql.yml up -d --build

# 宿主机端口映射
FRONTEND_PORT=8080
BACKEND_PORT=3001

# 外置 MySQL 连接信息
# - 如果 MySQL 部署在宿主机本机，可优先尝试 host.docker.internal
# - 如果是局域网或云数据库，请替换为真实可达地址
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=y_link

# 是否允许 TypeORM 自动同步：
# - false：推荐，先执行 SQL 脚本后再启动
# - true：仅建议开发环境临时调试使用
DB_SYNC=false
