# 模块说明：Git 忽略配置
# 文件职责：声明 Git 版本控制中需要忽略的文件和目录
# 维护说明：新增临时文件或构建产物目录时，需同步在此文件补充规则

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local
.env
.env.docker.mysql
backend/.env
backend/data/
backend/uploads/*
!backend/uploads/.gitkeep
.local-dev/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.trae/
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
